{
  "compilerOptions": {
    "sourceMap": true,
    "target": "es5",
    "module": "node16",
    "lib": ["es5", "dom"],
    "types": ["cypress", "node"],
    "esModuleInterop": true,
    "moduleResolution": "node16",  // Add this line
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["**/*.ts"]
}
